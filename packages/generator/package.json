{
  "name": "@prelude/generator",
  "version": "9.0.0",
  "description": "Generator module.",
  "type": "module",
  "module": "./mjs/index.js",
  "exports": {
    ".": {
      "import": "./mjs/index.js"
    },
    "./*.js": {
      "import": "./mjs/*.js"
    }
  },
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "pnpm tsx --test src/**/*.test.ts --coverage",
    "preversion": "make preversion",
    "postversion": "make postversion"
  },
  "keywords": [
    "prelude",
    "std",
    "lib",
    "stdlib",
    "library",
    "generators",
    "functional",
    "combinators"
  ],
  "author": "Mirek Rusin (https://github.com/mirek)",
  "license": "CC0-1.0",
  "devDependencies": {
    "@swc-node/register": "1.11.1",
    "@prelude/tsconfig": "workspace:*"
  },
  "dependencies": {
    "@prelude/cmp": "workspace:*"
  }
}

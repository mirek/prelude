{
  "name": "@prelude/fs",
  "version": "1.0.0",
  "description": "Fs module.",
  "type": "module",
  "main": "./cjs/index.js",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "npx tsx --test src/**/*.test.ts --coverage",
    "preversion": "make preversion",
    "postversion": "make postversion"
  },
  "keywords": [
    "prelude",
    "std",
    "lib",
    "stdlib",
    "library"
  ],
  "author": "Mirek Rusin (https://github.com/mirek)",
  "license": "MIT",
  "devDependencies": {
    "@prelude/async-generator": "workspace:*"
  },
  "module": "./mjs/index.js",
  "exports": {
    ".": {
      "import": "./mjs/index.js",
      "require": "./cjs/index.js"
    },
    "./*.js": {
      "import": "./mjs/*.js",
      "require": "./cjs/*.js"
    },
    "./*": {
      "require": "./cjs/*.js"
    }
  },
  "dependencies": {
    "@prelude/radix-trie": "workspace:*"
  }
}

{
  "name": "@prelude/cmp",
  "version": "4.2.0",
  "description": "Cmp module.",
  "type": "module",
  "module": "./mjs/index.js",
  "main": "./cjs/index.js",
  "exports": {
    ".": {
      "import": "./mjs/index.js",
      "require": "./cjs/index.js"
    },
    "./*.js": {
      "import": "./mjs/*.js",
      "require": "./cjs/*.js"
    },
    "./*": {
      "require": "./cjs/*.js"
    }
  },
  "scripts": {
    "test": "eslint src && jest --coverage",
    "preversion": "make preversion",
    "postversion": "make postversion"
  },
  "keywords": [
    "prelude",
    "std",
    "lib",
    "stdlib",
    "library",
    "cmp",
    "compare",
    "sort",
    "order"
  ],
  "author": "Mirek Rusin (https://github.com/mirek)",
  "license": "MIT"
}

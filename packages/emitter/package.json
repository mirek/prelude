{
  "name": "@prelude/emitter",
  "version": "2.0.0",
  "description": "Emitter module.",
  "type": "module",
  "main": "./cjs/index.js",
  "packageManager": "pnpm@10.6.3",
  "scripts": {
    "test": "make test",
    "preversion": "make test",
    "postversion": "make postversion"
  },
  "keywords": [
    "prelude",

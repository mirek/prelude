{
  "name": "@prelude/repl",
  "version": "1.0.0",
  "description": "Repl package.",
  "type": "module",
  "main": "./cjs/index.js",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "make test",
    "preversion": "make preversion",
    "postversion": "make postversion"
  },
  "keywords": [
    "prelude",
    "std",
    "lib",
    "stdlib",
    "library",
    "repl",
    "eval"
  ],
  "author": "Mirek Rusin (https://github.com/mirek)",
  "license": "CC0-1.0",
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5"
  },
  "module": "./mjs/index.js",
  "exports": {
    ".": {
      "import": "./mjs/index.js",
      "require": "./cjs/index.js"
    },
    "./*.js": {
      "import": "./mjs/*.js",
      "require": "./cjs/*.js"
    },
    "./*": {
      "import": "./mjs/*.js",
      "require": "./cjs/*.js"
    }
  },
  "packageManager": "pnpm@10.6.5"
}

{
  "name": "@prelude/babel-plugin-transform-import-meta",
  "version": "1.0.0",
  "description": "Babel plugin transforms import.meta in emitted CJS.",
  "type": "module",
  "main": "./cjs/index.js",
  "module": "./mjs/index.js",
  "scripts": {
    "test": "NODE_OPTIONS='--no-warnings --experimental-vm-modules' pnpm npx tsx --test src/**/*.test.ts",
    "preversion": "make preversion",
    "postversion": "make postversion"
  },
  "keywords": [
    "prelude",
    "std",
    "lib",
    "stdlib",
    "library",
    "esm",
    "cjs",
    "babel",
    "babel-plugin",
    "import",
    "meta",
    "url",
    "dirname",
    "filename"
  ],
  "author": "Mirek Rusin (https://github.com/mirek)",
  "license": "CC0-1.0",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/types": "^7.29.0",
    "@types/babel__core": "^7.20.5"
  },
  "exports": {
    ".": {
      "import": "./mjs/index.js",
      "require": "./cjs/index.js"
    },
    "./*.js": {
      "import": "./mjs/*.js",
      "require": "./cjs/*.js"
    },
    "./*": {
      "import": "./mjs/*.js",
      "require": "./cjs/*.js"
    }
  },
  "packageManager": "pnpm@10.8.1",
  "peerDependencies": {
    "@babel/core": "^7.26.10",
    "@babel/types": "^7.27.0"
  }
}
